# ==========================================
# Globales del Monorepositorio
# ==========================================
# Al no ponerle una barra (/) adelante, ignora estas carpetas estén donde estén
node_modules/
dist/
coverage/
.tmp/
.temp/

# Archivos de Sistema
.DS_Store
Thumbs.db
desktop.ini

# Logs generales
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================
# Configuración específica: Backend (NestJS)
# ==========================================
# ¡CRÍTICO! Protege tus credenciales de MongoDB y JWT en el Back
/backend/.env
/backend/.env.*
/backend/.env.local

# Datos de ejecución de Node
/backend/pids
/backend/*.pid
/backend/*.seed
/backend/*.pid.lock

# ==========================================
# Configuración específica: Frontend (Angular)
# ==========================================
/frontend/.angular/cache/
/frontend/out-tsc/
/frontend/bazel-out/

# ==========================================
# Entornos de Desarrollo (IDEs)
# ==========================================
.idea/
.vscode/
*.sublime-workspace
*.launch